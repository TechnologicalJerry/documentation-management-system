{
  "name": "devdocs-studio-backend-fastify",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run --workspaces",
    "test:watch": "vitest --workspaces",
    "lint": "npm run lint --workspaces --if-present",
    "dev:gateway": "npm run dev -w @devdocs/api-gateway",
    "dev:auth": "npm run dev -w @devdocs/auth-service",
    "dev:user": "npm run dev -w @devdocs/user-service",
    "dev:project": "npm run dev -w @devdocs/project-service",
    "dev:document": "npm run dev -w @devdocs/document-service",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
