NODE_ENV=development
PORT=3008
MONGODB_URI=mongodb://localhost:27017/devdocs_export
RABBITMQ_URL=amqp://guest:guest@localhost:5672
JWT_SECRET=your-jwt-secret
SERVICE_NAME=export-service
LOG_LEVEL=info
DOCUMENT_SERVICE_URL=http://localhost:3005
FILE_SERVICE_URL=http://localhost:3009
EXPORT_STORAGE_PATH=/tmp/exports
MAX_EXPORT_SIZE_MB=50
EXPORT_EXPIRY_HOURS=24

# MongoDB tuning
MONGODB_POOL_SIZE=10
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# CORS
CORS_ORIGIN=http://localhost:4200,http://localhost:3000

# RabbitMQ exchange/queue
RABBITMQ_EXCHANGE=devdocs.events
RABBITMQ_QUEUE=export-service-queue

# Logging
LOG_FORMAT=json

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
