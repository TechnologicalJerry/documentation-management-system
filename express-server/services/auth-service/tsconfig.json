{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@devdocs/shared-types": ["../../packages/shared-types/src"],
      "@devdocs/shared-utils": ["../../packages/shared-utils/src"],
      "@devdocs/shared-middleware": ["../../packages/shared-middleware/src"],
      "@devdocs/shared-config": ["../../packages/shared-config/src"],
      "@devdocs/event-bus": ["../../packages/event-bus/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/tests/**/*.test.ts"]
}
