{
  "name": "@devdocs/ai-service",
  "version": "1.0.0",
  "description": "AI-powered documentation generation service for DevDocs Studio",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "private": true,
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest --runInBand --forceExit --passWithNoTests",
    "test:unit": "jest --testPathPattern=tests/unit --runInBand",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@devdocs/event-bus": "*",
    "@devdocs/shared-config": "*",
    "@devdocs/shared-middleware": "*",
    "@devdocs/shared-types": "*",
    "@devdocs/shared-utils": "*",
    "amqplib": "^0.10.4",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "jsonwebtoken": "^9.0.2",
    "eventsource": "^2.0.2",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "http-status-codes": "^2.3.0",
    "mongoose": "^8.4.1",
    "openai": "^4.52.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/eventsource": "^1.1.15",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src/tests"],
    "moduleNameMapper": {
      "@devdocs/shared-types": "<rootDir>/../../packages/shared-types/src",
      "@devdocs/shared-utils": "<rootDir>/../../packages/shared-utils/src",
      "@devdocs/shared-middleware": "<rootDir>/../../packages/shared-middleware/src",
      "@devdocs/shared-config": "<rootDir>/../../packages/shared-config/src",
      "@devdocs/event-bus": "<rootDir>/../../packages/event-bus/src"
    },
    "coverageDirectory": "coverage",
    "coverageReporters": ["text", "lcov", "html"],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts",
      "!src/tests/**",
      "!src/**/*.d.ts"
    ]
  }
}
