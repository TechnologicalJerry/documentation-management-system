# Application
NODE_ENV=development
PORT=3005
SERVICE_NAME=template-service

# MongoDB
MONGODB_URI=mongodb://localhost:27017/devdocs_templates
MONGODB_POOL_SIZE=10
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000

# JWT (for token verification — shared secret with auth-service)
JWT_SECRET=change-this-in-production-use-a-long-random-secret

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# CORS
CORS_ORIGIN=http://localhost:4200,http://localhost:3000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Pagination defaults
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Template settings
MAX_TEMPLATE_SIZE_BYTES=524288
SEED_SYSTEM_TEMPLATES=true
