NODE_ENV=development
PORT=3011
SERVICE_NAME=audit-service

# MongoDB
MONGODB_URI=mongodb://localhost:27017/devdocs_audit
MONGODB_POOL_SIZE=10
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000

# JWT (shared secret with auth-service for token verification)
JWT_SECRET=your-jwt-secret

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=devdocs.events
RABBITMQ_QUEUE=audit-service-queue

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# CORS
CORS_ORIGIN=http://localhost:4200,http://localhost:3000

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Data retention (days; set to 0 to disable automatic cleanup)
AUDIT_RETENTION_DAYS=365
