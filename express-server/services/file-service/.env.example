NODE_ENV=development
PORT=3009
MONGODB_URI=mongodb://localhost:27017/devdocs_files
RABBITMQ_URL=amqp://guest:guest@localhost:5672
JWT_SECRET=your-jwt-secret
SERVICE_NAME=file-service
LOG_LEVEL=info
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=/var/uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=devdocs-files
MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,text/markdown
BASE_URL=http://localhost:3009
MONGODB_POOL_SIZE=10
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=45000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
CORS_ORIGIN=http://localhost:4200,http://localhost:3000
THUMBNAIL_WIDTH=320
THUMBNAIL_HEIGHT=240
THUMBNAIL_QUALITY=80
LOG_FORMAT=json
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
