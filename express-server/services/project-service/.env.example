# Application
NODE_ENV=development
PORT=3002
SERVICE_NAME=project-service

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/devdocs_projects?schema=public

# JWT (shared secret for inter-service validation)
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ISSUER=devdocs-auth-service

# RabbitMQ (Event Bus)
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=devdocs.events
RABBITMQ_QUEUE_PROJECT=project-service.events
RABBITMQ_QUEUE_USER=user-service.events

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:3000,http://localhost:4000

# Invitation
INVITATION_EXPIRY_HOURS=72
INVITATION_BASE_URL=http://localhost:4200

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
