# =============================================================================
# DevDocs Studio Backend - Environment Variables
# Copy this file to .env and fill in the actual values.
# NEVER commit the .env file to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# General / Shared
# -----------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=debug
# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# -----------------------------------------------------------------------------
# API Gateway  (@devdocs/api-gateway)
# -----------------------------------------------------------------------------
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
REQUEST_TIMEOUT_MS=30000

# Internal service base URLs (used by the gateway to proxy/forward requests)
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
PROJECT_SERVICE_URL=http://localhost:3003
DOCUMENT_SERVICE_URL=http://localhost:3004
TEMPLATE_SERVICE_URL=http://localhost:3005
AI_SERVICE_URL=http://localhost:3006
EXPORT_SERVICE_URL=http://localhost:3007
FILE_SERVICE_URL=http://localhost:3008
NOTIFICATION_SERVICE_URL=http://localhost:3009
AUDIT_SERVICE_URL=http://localhost:3010
ANALYTICS_SERVICE_URL=http://localhost:3011

# -----------------------------------------------------------------------------
# Auth Service  (@devdocs/auth-service)
# -----------------------------------------------------------------------------
AUTH_SERVICE_PORT=3001
AUTH_SERVICE_HOST=0.0.0.0

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Session
SESSION_SECRET=change-me-session-secret-at-least-32-chars
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

# OAuth - GitHub
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# OAuth - Microsoft / Azure AD
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_URL=http://localhost:3000/auth/microsoft/callback

# Password hashing
BCRYPT_ROUNDS=12

# MFA / TOTP
MFA_ISSUER=DevDocs Studio
MFA_WINDOW=1

# Email verification & password-reset token TTL
EMAIL_VERIFICATION_TTL_SECONDS=86400
PASSWORD_RESET_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# User Service  (@devdocs/user-service)
# -----------------------------------------------------------------------------
USER_SERVICE_PORT=3002
USER_SERVICE_HOST=0.0.0.0

# Pagination defaults
USER_DEFAULT_PAGE_SIZE=20
USER_MAX_PAGE_SIZE=100

# Avatar storage prefix (relative to the file-service root)
USER_AVATAR_PREFIX=avatars

# -----------------------------------------------------------------------------
# Project Service  (@devdocs/project-service)
# -----------------------------------------------------------------------------
PROJECT_SERVICE_PORT=3003
PROJECT_SERVICE_HOST=0.0.0.0

PROJECT_DEFAULT_PAGE_SIZE=20
PROJECT_MAX_PAGE_SIZE=100

# -----------------------------------------------------------------------------
# Document Service  (@devdocs/document-service)
# -----------------------------------------------------------------------------
DOCUMENT_SERVICE_PORT=3004
DOCUMENT_SERVICE_HOST=0.0.0.0

DOCUMENT_DEFAULT_PAGE_SIZE=20
DOCUMENT_MAX_PAGE_SIZE=100

# Collaborative editing (Yjs WebSocket)
DOCUMENT_COLLAB_ENABLED=true
DOCUMENT_COLLAB_PORT=4004
# Max document body size in bytes (default 10 MB)
DOCUMENT_MAX_SIZE_BYTES=10485760

# Full-text search backend: elasticsearch | meilisearch | none
DOCUMENT_SEARCH_BACKEND=elasticsearch

# -----------------------------------------------------------------------------
# Template Service  (@devdocs/template-service)
# -----------------------------------------------------------------------------
TEMPLATE_SERVICE_PORT=3005
TEMPLATE_SERVICE_HOST=0.0.0.0

TEMPLATE_DEFAULT_PAGE_SIZE=20
TEMPLATE_MAX_PAGE_SIZE=100

# -----------------------------------------------------------------------------
# AI Service  (@devdocs/ai-service)
# -----------------------------------------------------------------------------
AI_SERVICE_PORT=3006
AI_SERVICE_HOST=0.0.0.0

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_DEFAULT_MODEL=claude-opus-4-5
ANTHROPIC_MAX_TOKENS=4096

# OpenAI (optional fallback)
OPENAI_API_KEY=your-openai-api-key
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# AI feature flags
AI_AUTOCOMPLETE_ENABLED=true
AI_SUMMARIZE_ENABLED=true
AI_TRANSLATE_ENABLED=true
AI_GRAMMAR_CHECK_ENABLED=true
AI_MAX_CONCURRENT_REQUESTS=10

# Rate limiting for AI endpoints (per user per minute)
AI_RATE_LIMIT_RPM=20

# -----------------------------------------------------------------------------
# Export Service  (@devdocs/export-service)
# -----------------------------------------------------------------------------
EXPORT_SERVICE_PORT=3007
EXPORT_SERVICE_HOST=0.0.0.0

# Supported formats: pdf, docx, html, markdown, epub
EXPORT_SUPPORTED_FORMATS=pdf,docx,html,markdown,epub

# Puppeteer / headless Chrome for PDF rendering
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
PUPPETEER_NO_SANDBOX=false

# LibreOffice for DOCX rendering (path to soffice binary)
LIBREOFFICE_PATH=/usr/bin/soffice

# Temp directory for export artifacts
EXPORT_TEMP_DIR=/tmp/devdocs-exports
# Max export job TTL in seconds (1 hour)
EXPORT_JOB_TTL_SECONDS=3600

# -----------------------------------------------------------------------------
# File Service  (@devdocs/file-service)
# -----------------------------------------------------------------------------
FILE_SERVICE_PORT=3008
FILE_SERVICE_HOST=0.0.0.0

# Storage provider: local | s3 | gcs | azure
FILE_STORAGE_PROVIDER=local
FILE_LOCAL_UPLOAD_DIR=/var/devdocs/uploads
FILE_MAX_SIZE_BYTES=52428800
FILE_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml,application/pdf,text/plain,application/zip

# Amazon S3
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=devdocs-files
AWS_S3_PREFIX=uploads/
AWS_S3_ACL=private
AWS_CLOUDFRONT_DOMAIN=

# Google Cloud Storage
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=devdocs-files
GCS_KEY_FILE=/secrets/gcs-key.json

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT=your-storage-account
AZURE_STORAGE_ACCESS_KEY=your-storage-access-key
AZURE_STORAGE_CONTAINER=devdocs-files

# CDN / public base URL for served files
FILE_PUBLIC_BASE_URL=http://localhost:3008/files

# Virus scanning (ClamAV)
FILE_VIRUS_SCAN_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Image processing (Sharp)
FILE_IMAGE_OPTIMIZATION_ENABLED=true
FILE_IMAGE_MAX_WIDTH=2048
FILE_IMAGE_MAX_HEIGHT=2048
FILE_IMAGE_QUALITY=85

# -----------------------------------------------------------------------------
# Notification Service  (@devdocs/notification-service)
# -----------------------------------------------------------------------------
NOTIFICATION_SERVICE_PORT=3009
NOTIFICATION_SERVICE_HOST=0.0.0.0

# Email provider: smtp | sendgrid | ses | mailgun | resend
EMAIL_PROVIDER=smtp

# SMTP
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_ADDRESS=noreply@devdocsstudio.com
SMTP_FROM_NAME=DevDocs Studio

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_ADDRESS=noreply@devdocsstudio.com

# AWS SES
SES_REGION=us-east-1
SES_FROM_ADDRESS=noreply@devdocsstudio.com

# Mailgun
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.devdocsstudio.com

# Resend
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_ADDRESS=noreply@devdocsstudio.com

# Push notifications (Web Push / VAPID)
PUSH_NOTIFICATIONS_ENABLED=false
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@devdocsstudio.com

# In-app WebSocket notifications
NOTIFICATION_WS_ENABLED=true
NOTIFICATION_WS_PORT=4009

# Slack integration
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Webhook delivery
NOTIFICATION_WEBHOOK_RETRY_ATTEMPTS=3
NOTIFICATION_WEBHOOK_RETRY_DELAY_MS=5000

# -----------------------------------------------------------------------------
# Audit Service  (@devdocs/audit-service)
# -----------------------------------------------------------------------------
AUDIT_SERVICE_PORT=3010
AUDIT_SERVICE_HOST=0.0.0.0

# How long to retain audit log entries (in days)
AUDIT_RETENTION_DAYS=365
AUDIT_DEFAULT_PAGE_SIZE=50
AUDIT_MAX_PAGE_SIZE=200

# Async write queue
AUDIT_QUEUE_FLUSH_INTERVAL_MS=5000
AUDIT_QUEUE_MAX_BATCH_SIZE=100

# -----------------------------------------------------------------------------
# Analytics Service  (@devdocs/analytics-service)
# -----------------------------------------------------------------------------
ANALYTICS_SERVICE_PORT=3011
ANALYTICS_SERVICE_HOST=0.0.0.0

ANALYTICS_RETENTION_DAYS=90
ANALYTICS_DEFAULT_PAGE_SIZE=50

# Optional: forward events to a third-party provider
ANALYTICS_POSTHOG_ENABLED=false
POSTHOG_API_KEY=your-posthog-api-key
POSTHOG_HOST=https://app.posthog.com

ANALYTICS_SEGMENT_ENABLED=false
SEGMENT_WRITE_KEY=your-segment-write-key

# -----------------------------------------------------------------------------
# PostgreSQL (primary relational database)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=devdocs
POSTGRES_PASSWORD=devdocs_password
POSTGRES_DB=devdocs_studio
POSTGRES_SCHEMA=public
POSTGRES_SSL=false
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_IDLE_TIMEOUT_MS=30000
POSTGRES_CONNECTION_TIMEOUT_MS=5000

# Auth DB (can be the same instance with a different schema/db)
AUTH_DB_HOST=localhost
AUTH_DB_PORT=5432
AUTH_DB_USER=devdocs
AUTH_DB_PASSWORD=devdocs_password
AUTH_DB_NAME=devdocs_auth
AUTH_DB_SSL=false

# -----------------------------------------------------------------------------
# MongoDB (document store)
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://devdocs:devdocs_password@localhost:27017/devdocs_studio?authSource=admin
MONGODB_DB_NAME=devdocs_studio
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# -----------------------------------------------------------------------------
# Redis (cache, sessions, queues, pub/sub)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false
REDIS_KEY_PREFIX=devdocs:
REDIS_SOCKET_TIMEOUT_MS=5000
REDIS_MAX_RETRIES_PER_REQUEST=3

# Redis Sentinel (optional high-availability setup)
REDIS_SENTINEL_ENABLED=false
REDIS_SENTINEL_HOSTS=localhost:26379,localhost:26380,localhost:26381
REDIS_SENTINEL_NAME=mymaster

# -----------------------------------------------------------------------------
# Elasticsearch  (full-text search for documents)
# -----------------------------------------------------------------------------
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_INDEX_PREFIX=devdocs_
ELASTICSEARCH_MAX_RESULT_WINDOW=10000

# -----------------------------------------------------------------------------
# Meilisearch  (alternative full-text search)
# -----------------------------------------------------------------------------
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-master-key

# -----------------------------------------------------------------------------
# RabbitMQ / AMQP (async messaging between services)
# -----------------------------------------------------------------------------
RABBITMQ_URL=amqp://devdocs:devdocs_password@localhost:5672
RABBITMQ_VHOST=/
RABBITMQ_EXCHANGE=devdocs.events
RABBITMQ_PREFETCH_COUNT=10
RABBITMQ_HEARTBEAT_SECONDS=60

# -----------------------------------------------------------------------------
# Bull / BullMQ (job queues backed by Redis)
# -----------------------------------------------------------------------------
BULL_QUEUE_PREFIX=devdocs:queue
BULL_JOB_ATTEMPTS=3
BULL_JOB_BACKOFF_TYPE=exponential
BULL_JOB_BACKOFF_DELAY_MS=2000
BULL_CONCURRENCY=5

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------

# OpenTelemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=devdocs-studio
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1

# Prometheus metrics
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Sentry error tracking
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.1

# New Relic
NEW_RELIC_ENABLED=false
NEW_RELIC_LICENSE_KEY=your-new-relic-license-key
NEW_RELIC_APP_NAME=DevDocs Studio

# Datadog
DATADOG_ENABLED=false
DD_API_KEY=your-datadog-api-key
DD_AGENT_HOST=localhost
DD_TRACE_AGENT_PORT=8126
